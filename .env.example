# Local Postgres 18 from Code/compose.yaml
# Host port: 5432
# Database: content_foundation
# Username/password: postgres / postgres
#
# Quick start:
# 1. docker compose up -d
# 2. export DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/content_foundation
# 3. export CONTENT_FOUNDATION_SECRET=$(openssl rand -hex 32)
# 4. pnpm db:migrate
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/content_foundation
CONTENT_FOUNDATION_SECRET=replace-with-a-random-secret
