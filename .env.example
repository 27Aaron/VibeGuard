# Local Postgres 18 from Code/compose.yaml
# Host port: 5432
# Database: vibeguard
# Username/password: postgres / postgres
#
# Quick start:
# 1. cp .env.example .env
# 2. replace VIBEGUARD_SECRET with: openssl rand -hex 32
# 3. docker compose up -d
# 4. pnpm db:migrate
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vibeguard
VIBEGUARD_SECRET=replace-with-a-random-secret
ADMIN_PASSWORD=replace-with-a-strong-admin-password
