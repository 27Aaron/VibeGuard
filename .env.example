# VibeGuard environment template
#
# Quick start:
# 1. cp .env.example .env
# 2. Replace VIBEGUARD_SECRET with: openssl rand -hex 32
# 3. Replace ADMIN_PASSWORD with a strong password, at least 12 characters.
# 4. pnpm dev:stack
#
# Notes:
# - .env is local/private and must not be committed.
# - Model provider credentials are configured in the Admin UI, then encrypted
#   with VIBEGUARD_SECRET. Keep that secret stable once real credentials exist.

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------

# Local Postgres defaults:
# - Host port: 5432
# - Database: vibeguard
# - Username/password: postgres / postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/vibeguard

# Public base URL used by local MCP clients and server-side helpers.
# For production, set this to the public HTTPS origin, for example:
# https://vibeguard.example.com
VIBEGUARD_API_URL=http://127.0.0.1:3000

# Local dev server bind address. Keep HOSTNAME local unless you really need LAN
# access.
HOSTNAME=127.0.0.1
PORT=3000

# Required secrets. Do not reuse the example values.
VIBEGUARD_SECRET=replace-with-a-random-secret
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Optional database pool tuning. Defaults are shown for clarity.
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=5000
DB_SSL=false

# -----------------------------------------------------------------------------
# LLM reliability tuning
# -----------------------------------------------------------------------------

# One provider request attempt may run up to this timeout. The SDK's own retries
# are disabled; VibeGuard applies the bounded retry policy below instead.
VIBEGUARD_LLM_TIMEOUT_MS=60000
VIBEGUARD_LLM_MAX_ATTEMPTS=3
VIBEGUARD_LLM_RETRY_BASE_MS=500
VIBEGUARD_LLM_RETRY_MAX_MS=8000

# -----------------------------------------------------------------------------
# MCP endpoint hardening
# -----------------------------------------------------------------------------

# Empty token means open local/dev usage. For any public deployment, set a
# 32+ character random token and pass it from clients.
VIBEGUARD_MCP_API_TOKEN=
VIBEGUARD_MCP_MAX_SESSIONS=100
VIBEGUARD_MCP_SESSION_TTL_MS=60000

# Only enable this behind a trusted reverse proxy that overwrites
# X-Forwarded-For and X-Real-IP.
VIBEGUARD_TRUST_PROXY_HEADERS=false

# -----------------------------------------------------------------------------
# Worker and sync loop
# -----------------------------------------------------------------------------

# Worker polling cadence. Keep the poll interval modest; long-running LLM calls
# are controlled by VIBEGUARD_LLM_* above.
WORKER_POLL_INTERVAL_MS=5000
WORKER_MAX_IDLE_INTERVAL_MS=60000

# Security data sync cadence. Default is every 3 hours.
OSV_SYNC_INTERVAL_MS=10800000

# Set true only when database migrations/bootstrap are handled externally.
VIBEGUARD_SKIP_DB_BOOTSTRAP=false

# -----------------------------------------------------------------------------
# Security data sync guards
# -----------------------------------------------------------------------------

# Local cache directories. Relative paths are resolved from the repo root.
VIBEGUARD_OSV_CACHE_DIR=data/osv-cache
VIBEGUARD_OSV_BOOTSTRAP_DIR=data/osv-bootstrap
VIBEGUARD_ENRICHMENT_CACHE_DIR=data/enrichment-cache

# Download and parsing safety limits. The defaults are intentionally conservative
# for a local dev machine; raise them only after checking host resources.
VIBEGUARD_OSV_MODIFIED_ID_ROW_LIMIT=2000
VIBEGUARD_OSV_VULNERABILITY_TEXT_BYTES=2097152
VIBEGUARD_NVD_CONCURRENCY=1
VIBEGUARD_CISA_KEV_JSON_BYTES=8388608
VIBEGUARD_EPSS_CSV_GZ_BYTES=16777216
VIBEGUARD_EPSS_CSV_TEXT_BYTES=67108864
VIBEGUARD_NVD_FEED_GZ_BYTES=67108864
VIBEGUARD_NVD_FEED_JSON_BYTES=536870912

# -----------------------------------------------------------------------------
# Image proxy hardening
# -----------------------------------------------------------------------------

# Public image relay endpoint limits. These protect the server from large files,
# slow upstreams, redirect loops, and repeated DNS work.
IMAGE_PROXY_MAX_BYTES=5000000
IMAGE_PROXY_FETCH_TIMEOUT_MS=10000
IMAGE_PROXY_MAX_REDIRECTS=3
IMAGE_PROXY_DNS_CACHE_SIZE=128
IMAGE_PROXY_DNS_CACHE_TTL_MS=60000
