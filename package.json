{
  "name": "content-foundation",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter ingestion-worker dev",
    "dev:stack": "node scripts/dev-stack.mjs",
    "build:web": "pnpm --filter web build",
    "lint:web": "pnpm --filter web lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "lint": "pnpm lint:web",
    "test": "vitest run",
    "typecheck": "pnpm --dir apps/web exec tsc --noEmit --project tsconfig.json && pnpm exec tsc --noEmit --project tsconfig.workspace.json"
  },
  "dependencies": {
    "@content-foundation/db": "workspace:*",
    "@content-foundation/llm": "workspace:*",
    "@content-foundation/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "vitest": "^4.1.6"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12",
      "postcss": "8.5.15"
    }
  }
}
