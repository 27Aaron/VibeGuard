{
  "name": "vibeguard",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev:web": "node scripts/with-env.mjs --local-defaults pnpm --filter web dev",
    "dev:worker": "node scripts/with-env.mjs --local-defaults pnpm --filter worker dev",
    "dev:stack": "node scripts/dev-stack.mjs",
    "build:web": "node scripts/with-env.mjs --local-defaults pnpm --filter web build",
    "lint": "node scripts/with-env.mjs pnpm --filter web lint",
    "db:generate": "node scripts/with-env.mjs --local-defaults drizzle-kit generate",
    "db:migrate": "node scripts/with-env.mjs --local-defaults drizzle-kit migrate",
    "osv:sync": "node scripts/with-env.mjs --local-defaults pnpm --filter worker exec tsx src/sync-osv.ts",
    "test": "node scripts/with-env.mjs vitest run",
    "typecheck": "node scripts/with-env.mjs pnpm --dir apps/web exec tsc --noEmit --project tsconfig.json && node scripts/with-env.mjs pnpm exec tsc --noEmit --project tsconfig.workspace.json"
  },
  "dependencies": {
    "@vibeguard/db": "workspace:*",
    "@vibeguard/llm": "workspace:*",
    "@vibeguard/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/semver": "^7.7.1",
    "drizzle-kit": "^0.31.10",
    "react": "19.2.6",
    "tsx": "^4.20.6",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12",
      "postcss": "8.5.15"
    }
  }
}
